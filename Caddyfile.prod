# TLS terminator for production. Cloudflare (SSL mode "Full") connects to
# origin :443 and accepts the locally-signed cert `tls internal` produces —
# real ACME is impossible here because port 80 belongs to a neighbour project.
{
	admin off
	auto_https disable_redirects
}

dicta-voluptatem-voluptatem.top {
	tls internal
	reverse_proxy app:8000
}
