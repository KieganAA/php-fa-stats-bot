{
    "manifest_version": 3,
    "name": "bot-stats helper",
    "short_name": "bot-stats",
    "version": "0.4.0",
    "description": "Подписка на кампании AIO в Telegram-боте fa-stats: сплиты и MVT одним кликом",

    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },

    "permissions": [
        "storage"
    ],

    "host_permissions": [
        "https://app.aio.tech/*",
        "http://localhost/*",
        "https://*/*"
    ],

    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "bot-stats",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png"
        }
    },

    "background": {
        "service_worker": "background.js",
        "type": "module"
    },

    "content_scripts": [
        {
            "matches": ["https://app.aio.tech/*"],
            "js": ["content.js"],
            "css": ["content.css"],
            "run_at": "document_idle"
        }
    ],

    "options_ui": {
        "page": "options/options.html",
        "open_in_tab": false
    }
}
