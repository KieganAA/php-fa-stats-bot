APP_NAME=fa-stats-bot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_PORT=8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (Postgres in docker-compose) ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=fa_stats
DB_USERNAME=fa
DB_PASSWORD=secret

# --- Redis ---
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Drivers (all through Redis) ---
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Octane ---
OCTANE_SERVER=frankenphp

# --- Telegram bot ---
TELEGRAM_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated Telegram user IDs (numeric). Leave empty to skip ID check.
TELEGRAM_ALLOWED_USER_IDS=
# Comma-separated Telegram usernames (with or without @). Leave empty to skip username check.
# If BOTH lists are empty, anyone can use the bot.
TELEGRAM_ALLOWED_USERNAMES=
# Per-user sliding-window command rate limit. 0 disables.
TELEGRAM_RATE_LIMIT=30
TELEGRAM_RATE_WINDOW_SECONDS=60

# --- AIO API ---
AIO_BASE_URL=https://app.aio.tech
AIO_TOKEN=
AIO_RATE_LIMIT_PER_MINUTE=60
AIO_CONCURRENCY_LIMIT=3
AIO_HEAVY_BUDGET_SECONDS=20

# --- Anthropic (AI mode) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TIMEOUT_SECONDS=60
# Per-user sliding-window rate limit. 0 disables.
ANTHROPIC_RATE_LIMIT=30
ANTHROPIC_RATE_WINDOW_SECONDS=3600

# --- docker-compose defaults ---
USER_ID=1000
GROUP_ID=1000
